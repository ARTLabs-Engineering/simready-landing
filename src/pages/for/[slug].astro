---
import SeoPageTemplate from '../../components/SeoPageTemplate.astro';
import { ENGINE_PAGES } from '../../lib/seo-pages';
import '../../styles/global.css';

export function getStaticPaths() {
  return Object.keys(ENGINE_PAGES).map((slug) => ({
    params: { slug },
  }));
}

const { slug } = Astro.params;
const page = ENGINE_PAGES[slug];

if (!page) {
  return Astro.redirect('/');
}
---

<SeoPageTemplate page={page} />
