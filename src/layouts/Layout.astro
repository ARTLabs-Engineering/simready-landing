---
import { SITE } from '../lib/constants';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const { title = SITE.title, description = SITE.description } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <meta name="robots" content="index, follow" />
    <meta name="google-site-verification" content="pgxKsHJS3okZ-sfCaMmYASXNZ2-cXgc3v-xWoweBpIo" />
    <link rel="canonical" href={SITE.url} />

    <!-- Keywords for search engines -->
    <meta name="keywords" content="SimReady, simulation-ready assets, OpenUSD, robotics simulation, NVIDIA Isaac Sim, MuJoCo, Gazebo, Unreal Engine, physics estimation, collision meshes, domain randomization, sim-to-real, 3D asset conversion, embodied AI, robot training data" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Rigyd" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={`${SITE.url}/og-image.png`} />
    <meta property="og:url" content={SITE.url} />
    <meta property="og:locale" content="en_US" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@rigyd3d" />
    <meta name="twitter:creator" content="@rigyd3d" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={`${SITE.url}/og-image.png`} />

    <!-- Fonts: Space Grotesk + Geist Mono -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <link rel="preconnect" href="https://cdn.jsdelivr.net" crossorigin />
    <style is:inline>
      @font-face {
        font-family: 'Geist Mono';
        src: url('https://cdn.jsdelivr.net/npm/geist@1.3.1/dist/fonts/geist-mono/GeistMono-Regular.woff2') format('woff2');
        font-weight: 400;
        font-style: normal;
        font-display: swap;
      }
    </style>

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <title>{title}</title>

    <!-- RB2B Tracking -->
    <script is:inline>!function(key) {if (window.reb2b) return;window.reb2b = {loaded: true};var s = document.createElement("script");s.async = true;s.src = "https://ddwl4m2hdecbv.cloudfront.net/b/" + key + "/" + key + ".js.gz";document.getElementsByTagName("script")[0].parentNode.insertBefore(s, document.getElementsByTagName("script")[0]);}("EN4M0HLPX5OM");</script>

    <!-- Google Analytics -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-J1C7YQDPKX"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-J1C7YQDPKX');
    </script>

    <!-- Structured Data: Organization -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": "Rigyd",
      "url": "https://rigyd.com",
      "logo": `${SITE.url}/favicon.svg`,
      "description": "Rigyd is an AI-native infrastructure for converting raw 3D models into physics-enabled, simulation-ready OpenUSD assets for robotics training.",
      "parentOrganization": {
        "@type": "Organization",
        "name": "artlabs",
        "url": "https://artlabs.ai"
      },
      "sameAs": [
        "https://x.com/rigyd3d",
        "https://www.youtube.com/@rigyd3d",
        "https://linkedin.com/company/artlabs-ai",
        "https://github.com/ARTLabs-Engineering",
        "https://twitter.com/artlabs_ai"
      ]
    })} />

    <!-- Structured Data: SoftwareApplication -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "SoftwareApplication",
      "name": "Rigyd",
      "applicationCategory": "DeveloperApplication",
      "applicationSubCategory": "Robotics Simulation Tool",
      "description": description,
      "operatingSystem": "Web",
      "url": "https://rigyd.com",
      "offers": [
        {
          "@type": "Offer",
          "name": "Starter",
          "price": "29",
          "priceCurrency": "USD",
          "billingIncrement": "monthly",
          "description": "30 SimReady objects per month with priority support"
        },
        {
          "@type": "Offer",
          "name": "Enterprise",
          "price": "0",
          "priceCurrency": "USD",
          "description": "Custom pricing with API access and dedicated support"
        }
      ],
      "creator": {
        "@type": "Organization",
        "name": "artlabs",
        "url": "https://artlabs.ai"
      },
      "featureList": [
        "AI-powered physics estimation (mass, friction, restitution)",
        "Automatic collision mesh generation via convex decomposition",
        "OpenUSD output with USDPhysics schemas",
        "Compatible with NVIDIA Isaac Sim, MuJoCo, Gazebo, Unreal Engine",
        "Supports .glb, .fbx, .obj input formats",
        "97% cost reduction vs manual workflows"
      ]
    })} />

    <!-- Structured Data: FAQPage -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "What is a SimReady asset?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "A SimReady (SimReady) asset is a 3D model enriched with the metadata and physical properties needed for accurate simulation. This includes rigid-body physics (mass, friction, restitution), collision meshes, semantic labels, and material specifications — all built on OpenUSD. Unlike a regular 3D model that only contains geometry and textures, a SimReady asset can be dropped directly into simulators like NVIDIA Isaac Sim, MuJoCo, or Gazebo and behave realistically. Rigyd automates this entire enrichment process using AI."
          }
        },
        {
          "@type": "Question",
          "name": "What file formats does Rigyd accept?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Rigyd currently accepts .glb (glTF Binary), .fbx (Autodesk FBX), and .obj (Wavefront OBJ) files. No pre-processing or format conversion is needed before upload. Generation from 2D images and text descriptions is coming soon."
          }
        },
        {
          "@type": "Question",
          "name": "Do I need to pre-process my 3D models before uploading?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "No. Rigyd handles everything automatically — file size optimization, mesh geometry cleanup, physics property estimation, collision mesh generation, and semantic labeling. Upload your raw 3D files and get simulation-ready OpenUSD output in minutes."
          }
        },
        {
          "@type": "Question",
          "name": "How does scaling SimReady asset generation improve sim-to-real transfer?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "The sim-to-real gap is primarily a data quality problem. When simulated objects have inaccurate physics — wrong mass, unrealistic friction, or oversimplified collision geometry — policies trained in simulation fail on real hardware. Rigyd generates thousands of physics-accurate assets with calibrated mass (within 15-20% of measured values) and friction (within plus or minus 0.1 coefficient), giving domain randomization a realistic baseline to work from. More diverse, physically accurate training data leads to 40% better real-world performance."
          }
        },
        {
          "@type": "Question",
          "name": "What if we need thousands of assets?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Rigyd's Enterprise plan includes API access for batch processing, so you can convert entire 3D catalogs programmatically. Contact us at https://cal.com/ugur-yekta/30min to discuss your volume needs and get a custom plan."
          }
        }
      ]
    })} />

    <!-- Structured Data: HowTo -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "HowTo",
      "name": "How to create simulation-ready assets with Rigyd",
      "description": "Convert any 3D model into a physics-enabled OpenUSD asset in three steps.",
      "totalTime": "PT5M",
      "step": [
        {
          "@type": "HowToStep",
          "position": 1,
          "name": "Upload",
          "text": "Drop images / 3D models or describe what you need."
        },
        {
          "@type": "HowToStep",
          "position": 2,
          "name": "AI estimates physics",
          "text": "Rigyd generates collision meshes, identifies materials, and estimates mass, friction, and center of mass using AI."
        },
        {
          "@type": "HowToStep",
          "position": 3,
          "name": "Download SimReady USD",
          "text": "Download validated OpenUSD with USDPhysics schemas, ready for NVIDIA Isaac Sim, MuJoCo, Gazebo, and Unreal Engine."
        }
      ]
    })} />
  </head>
  <body class="grid-bg min-h-screen relative">
    <slot />

    <!-- Scroll reveal observer -->
    <script>
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add('visible');
              observer.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.1, rootMargin: '0px 0px -40px 0px' }
      );

      document.querySelectorAll('.reveal').forEach((el) => observer.observe(el));
    </script>
  </body>
</html>
