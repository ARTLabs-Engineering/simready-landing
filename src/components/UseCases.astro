---
const useCases = [
  {
    number: '01',
    title: 'Humanoids',
    description: 'Thousands of varied objects and environments for full-body interaction and manipulation training',
  },
  {
    number: '02',
    title: 'Industrial Automation',
    description: 'Sim-ready parts, tools, and factory layouts for assembly, pick-and-place, and inspection training',
  },
  {
    number: '03',
    title: 'Mobile Robots',
    description: 'Collidable 3D worlds for drones, cleaning robots, and delivery bots to train navigation at scale',
  },
  {
    number: '04',
    title: 'General Purpose',
    description: 'Physics-accurate 3D data for any robot that needs to learn to perceive and interact with the real world',
  },
];
---

<section id="use-cases" class="relative py-28 px-6">
  <div class="max-w-6xl mx-auto">
    <div class="mb-16 reveal">
      <h2 class="text-3xl sm:text-4xl md:text-5xl font-bold tracking-tight text-text leading-tight">
        3D data for every<br />form of <span class="italic text-amber">physical</span> AI.
      </h2>
    </div>

    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4">
      {useCases.map((item, i) => (
        <div
          class:list={[
            'reveal group p-6 rounded-xl border border-[rgba(255,255,255,0.08)] bg-bg-card/50 hover:border-[rgba(255,255,255,0.15)] transition-all duration-300 flex flex-col',
            i === 0 ? 'reveal-delay-1' : i === 1 ? 'reveal-delay-2' : i === 2 ? 'reveal-delay-3' : 'reveal-delay-4',
          ]}
        >
          <span class="text-xs font-mono text-text-secondary/40 mb-8 block">{item.number}</span>
          <h3 class="text-lg font-bold text-text mb-3">{item.title}</h3>
          <p class="text-sm text-text-secondary leading-relaxed">{item.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
