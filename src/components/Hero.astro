---
import TryNowButton from './TryNowButton.astro';
import Logo from './Logo.astro';
---

<section id="hero" class="relative min-h-screen flex items-center justify-center overflow-hidden pt-16 pb-24">
  <!-- Ambient glow -->
  <div class="absolute top-1/4 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[800px] h-[500px] bg-amber/[0.04] rounded-full blur-[120px] pointer-events-none"></div>

  <div class="relative z-10 max-w-6xl mx-auto px-4 sm:px-6 w-full">
    <!-- Nav -->
    <nav class="fixed top-0 left-0 right-0 z-50 backdrop-blur-md bg-bg/80 border-b border-[rgba(255,255,255,0.06)]">
      <div class="max-w-6xl mx-auto px-4 sm:px-6 h-14 flex items-center justify-between">
        <Logo />
        <div class="flex items-center gap-6">
          <a href="#how-it-works" class="text-sm text-text-secondary hover:text-text transition-colors hidden sm:block">How it works</a>
          <a href="#use-cases" class="text-sm text-text-secondary hover:text-text transition-colors hidden sm:block">Use Cases</a>
          <a href="#pricing" class="text-sm text-text-secondary hover:text-text transition-colors hidden sm:block">Pricing</a>
          <TryNowButton size="default" label="Try now" />
        </div>
      </div>
    </nav>

    <!-- Hero content -->
    <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center mt-12 lg:mt-0">
      <!-- Left: Copy -->
      <div class="space-y-6 text-center lg:text-left">
        <div class="inline-flex items-center gap-2 text-xs font-medium text-amber bg-amber/[0.08] border border-amber/20 rounded-full px-3 py-1.5">
          <span class="w-1.5 h-1.5 rounded-full bg-amber animate-pulse"></span>
          Now in beta
        </div>

        <h1 class="text-4xl sm:text-5xl lg:text-[3.5rem] font-bold leading-[1.08] tracking-tight text-text">
          Turn<br />
          <span id="rotating-word" class="inline-block text-text italic transition-opacity duration-500">images</span> into<br />
          <span class="text-amber">simulation-ready</span><br class="lg:hidden" /> assets in minutes
        </h1>

        <script>
          (() => {
            const words = ['images', 'descriptions', '3D objects'];
            let index = 0;
            const el = document.getElementById('rotating-word');
            if (!el) return;

            setInterval(() => {
              el.style.opacity = '0';
              setTimeout(() => {
                index = (index + 1) % words.length;
                el.textContent = words[index];
                el.style.opacity = '1';
              }, 500);
            }, 3000);
          })();
        </script>

        <p class="text-base sm:text-lg text-text-secondary leading-relaxed max-w-lg mx-auto lg:mx-0">
          Raw 3D/image/text in, physics-enabled OpenUSD out. The infrastructure for building millions of physics-accurate simulations across every scenario.
        </p>

        <div class="flex flex-col items-center lg:items-start gap-2 pt-2">
          <div class="flex flex-col sm:flex-row items-center lg:items-start justify-center lg:justify-start gap-4">
            <TryNowButton size="large" label="Start with 3 free credits" />
            <a href="#how-it-works" class="inline-flex items-center gap-2 px-6 py-3.5 text-sm font-medium text-text-secondary hover:text-text border border-border-hover rounded-lg transition-colors">
              See how it works
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
              </svg>
            </a>
          </div>
          <p class="text-xs text-text-secondary/80 text-center lg:text-left">
            One-time trial · No credit card required · Not a free tier
          </p>
        </div>

        <!-- Trust signals -->
        <div class="flex items-center justify-center lg:justify-start gap-6 pt-4 text-xs text-text-secondary">
          <span class="flex items-center gap-1.5">
            <svg class="w-3.5 h-3.5 text-green" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
            OpenUSD native
          </span>
          <span class="flex items-center gap-1.5">
            <svg class="w-3.5 h-3.5 text-green" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
            Physics-accurate
          </span>
          <span class="flex items-center gap-1.5">
            <svg class="w-3.5 h-3.5 text-green" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
            Omniverse asset-validated
          </span>
        </div>
      </div>

      <!-- Right: 3D Scene -->
      <div class="relative">
        <div id="scene-container" class="relative w-full aspect-square max-w-[520px] mx-auto">
          <!-- Three.js canvas mounts here -->
          <canvas id="hero-canvas" class="w-full h-full" role="img" aria-label="Interactive 3D model viewer showing a sim-ready asset with wireframe, textured, and physics-enabled SimReady views including mass, friction, and collision mesh overlay"></canvas>

          <!-- State indicator pills -->
          <div id="state-pills" class="absolute bottom-4 left-1/2 -translate-x-1/2 flex items-center gap-2 z-10">
            <button data-state="2" class="state-pill active px-3 py-1 text-xs font-mono rounded-full border transition-all" aria-label="View SimReady asset">
              SimReady
            </button>
            <button data-state="0" class="state-pill px-3 py-1 text-xs font-mono rounded-full border transition-all" aria-label="View wireframe mesh">
              Wireframe
            </button>
            <button data-state="1" class="state-pill px-3 py-1 text-xs font-mono rounded-full border transition-all" aria-label="View textured model">
              Textured
            </button>
          </div>

          <!-- Physics labels (shown in SimReady state) -->
          <div id="physics-labels" class="absolute inset-0 pointer-events-none opacity-0 transition-opacity duration-500 z-10">
            <div class="absolute top-[18%] right-[12%] font-mono text-xs text-amber bg-bg/80 backdrop-blur-sm px-2.5 py-1 rounded border border-amber/20">
              mass: 1.196 kg
            </div>
            <div class="absolute top-[45%] left-[8%] font-mono text-xs text-amber bg-bg/80 backdrop-blur-sm px-2.5 py-1 rounded border border-amber/20">
              friction: 0.55
            </div>
            <div class="absolute bottom-[25%] right-[15%] font-mono text-xs text-amber bg-bg/80 backdrop-blur-sm px-2.5 py-1 rounded border border-amber/20">
              material: aluminum + glass
            </div>
            <div class="absolute bottom-[38%] left-[12%] font-mono text-xs text-amber bg-bg/80 backdrop-blur-sm px-2.5 py-1 rounded border border-amber/20">
              restitution: 0.38
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  import * as THREE from 'three';
  import { GLTFLoader } from 'three/addons/loaders/GLTFLoader.js';
  import { DRACOLoader } from 'three/addons/loaders/DRACOLoader.js';

  const canvas = document.getElementById('hero-canvas') as HTMLCanvasElement;
  const container = document.getElementById('scene-container') as HTMLElement;
  const physicsLabels = document.getElementById('physics-labels') as HTMLElement;
  const statePills = document.querySelectorAll('.state-pill');

  if (canvas && container) {
    const scene = new THREE.Scene();
    const camera = new THREE.PerspectiveCamera(40, 1, 0.1, 100);
    camera.position.set(0, 0, 4.5);
    camera.lookAt(0, 0, 0);

    const renderer = new THREE.WebGLRenderer({
      canvas,
      antialias: true,
      alpha: true,
    });
    renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
    renderer.setClearColor(0x000000, 0);
    renderer.toneMapping = THREE.ACESFilmicToneMapping;
    renderer.toneMappingExposure = 1.2;

    function resize() {
      const rect = container.getBoundingClientRect();
      renderer.setSize(rect.width, rect.height);
      camera.aspect = rect.width / rect.height;
      camera.updateProjectionMatrix();
    }
    resize();
    window.addEventListener('resize', resize);

    // Lighting
    const ambientLight = new THREE.AmbientLight(0xffffff, 0.4);
    scene.add(ambientLight);

    const keyLight = new THREE.DirectionalLight(0xffffff, 1.2);
    keyLight.position.set(3, 5, 4);
    scene.add(keyLight);

    const fillLight = new THREE.DirectionalLight(0x3B82F6, 0.3);
    fillLight.position.set(-3, 2, -2);
    scene.add(fillLight);

    const rimLight = new THREE.DirectionalLight(0xd4e017, 0.4);
    rimLight.position.set(0, 3, -4);
    scene.add(rimLight);

    // Root group for the model
    const modelGroup = new THREE.Group();
    scene.add(modelGroup);

    // Materials for each state
    const wireframeMat = new THREE.MeshBasicMaterial({
      color: 0xfafafa,
      wireframe: true,
      transparent: true,
      opacity: 0.7,
    });

    const physicsWireMat = new THREE.MeshBasicMaterial({
      color: 0xd4e017,
      wireframe: true,
      transparent: true,
      opacity: 0.35,
    });

    const comMat = new THREE.MeshBasicMaterial({ color: 0xd4e017 });

    // State groups
    const wireGroup = new THREE.Group();
    const texGroup = new THREE.Group();
    const simGroup = new THREE.Group();
    wireGroup.visible = false;
    texGroup.visible = false;
    modelGroup.add(wireGroup, texGroup, simGroup);

    // ─── Load GLB model + collision mesh ────────────────────────
    // Load both in parallel, then use the collision mesh's bounding box
    // as the canonical center so the visual mesh sits inside the collision hull.
    const dracoLoader = new DRACOLoader();
    dracoLoader.setDecoderPath('/draco/');
    const loader = new GLTFLoader();
    loader.setDRACOLoader(dracoLoader);

    Promise.all([
      loader.loadAsync('/model.glb').then((gltf) => gltf.scene),
      loader.loadAsync('/collision.glb').then((gltf) => gltf.scene),
    ]).then(([model, colModel]) => {
        // Center and scale the visual model on its own bbox
        const visBox = new THREE.Box3().setFromObject(model);
        const visCenter = visBox.getCenter(new THREE.Vector3());
        const visSize = visBox.getSize(new THREE.Vector3());
        const maxDim = Math.max(visSize.x, visSize.y, visSize.z);
        const scale = 1.8 / maxDim;

        function prepareClone(src: THREE.Object3D) {
          const clone = src.clone();
          const pivot = new THREE.Group();
          pivot.add(clone);
          clone.position.set(-visCenter.x, -visCenter.y, -visCenter.z);
          pivot.scale.setScalar(scale);
          return pivot;
        }

        // State 0: Wireframe clone
        const wirePivot = prepareClone(model);
        wirePivot.traverse((child) => {
          if ((child as THREE.Mesh).isMesh) {
            (child as THREE.Mesh).material = wireframeMat;
          }
        });
        wireGroup.add(wirePivot);

        // State 1: Textured (original materials)
        const texPivot = prepareClone(model);
        texGroup.add(texPivot);

        // State 2: SimReady (original materials + physics overlay)
        const simPivot = prepareClone(model);
        simGroup.add(simPivot);

        // Collision mesh: rotate Z-up to Y-up, center on own bbox, scale to match
        const rotWrapper = new THREE.Group();
        rotWrapper.rotation.x = -Math.PI / 2;
        rotWrapper.add(colModel);
        rotWrapper.updateMatrixWorld(true);

        const colBox = new THREE.Box3().setFromObject(rotWrapper);
        const colCenter = colBox.getCenter(new THREE.Vector3());
        const colSize = colBox.getSize(new THREE.Vector3());
        const colMaxDim = Math.max(colSize.x, colSize.y, colSize.z);

        const colPivot = new THREE.Group();
        const colClone = rotWrapper.clone();
        colPivot.add(colClone);
        colClone.position.set(-colCenter.x, -colCenter.y, -colCenter.z);
        colPivot.scale.setScalar((1.8 / colMaxDim) * 1.02);

        colPivot.traverse((child) => {
          if ((child as THREE.Mesh).isMesh) {
            (child as THREE.Mesh).material = physicsWireMat;
          }
        });
        simGroup.add(colPivot);

        // Correct collision offset: measure world-space bbox centers and align
        simGroup.updateMatrixWorld(true);
        const simVisBox = new THREE.Box3().setFromObject(simPivot);
        const simVisCenter = simVisBox.getCenter(new THREE.Vector3());
        const simColBox = new THREE.Box3().setFromObject(colPivot);
        const simColCenter = simColBox.getCenter(new THREE.Vector3());
        colPivot.position.add(simVisCenter.sub(simColCenter));

        // Center of mass indicator
        const comGeom = new THREE.SphereGeometry(0.04, 16, 16);
        const comMesh = new THREE.Mesh(comGeom, comMat);
        simGroup.add(comMesh);

        // Axes helper
        const axisLength = 0.3;
        function makeAxis(dir: THREE.Vector3, color: number) {
          const arrowGeom = new THREE.CylinderGeometry(0.008, 0.008, axisLength, 6);
          arrowGeom.translate(0, axisLength / 2, 0);
          const arrowMat = new THREE.MeshBasicMaterial({ color });
          const arrow = new THREE.Mesh(arrowGeom, arrowMat);
          arrow.quaternion.setFromUnitVectors(new THREE.Vector3(0, 1, 0), dir);
          return arrow;
        }
        const axesGroup = new THREE.Group();
        axesGroup.add(makeAxis(new THREE.Vector3(1, 0, 0), 0xEF4444));
        axesGroup.add(makeAxis(new THREE.Vector3(0, 1, 0), 0x22C55E));
        axesGroup.add(makeAxis(new THREE.Vector3(0, 0, 1), 0x3B82F6));
        simGroup.add(axesGroup);
    }).catch((error: unknown) => {
        console.warn('Failed to load models:', error);
        // Fallback: show a placeholder cube
        const fallbackGeom = new THREE.BoxGeometry(0.8, 0.8, 0.8);
        wireGroup.add(new THREE.Mesh(fallbackGeom, wireframeMat));

        const fallbackMat = new THREE.MeshStandardMaterial({ color: 0xE8E0D4, roughness: 0.35 });
        texGroup.add(new THREE.Mesh(fallbackGeom, fallbackMat));

        const simMesh = new THREE.Mesh(fallbackGeom, fallbackMat.clone());
        const collisionGeom = new THREE.BoxGeometry(0.9, 0.9, 0.9);
        simGroup.add(simMesh, new THREE.Mesh(collisionGeom, physicsWireMat));

        const comGeom = new THREE.SphereGeometry(0.04, 16, 16);
        simGroup.add(new THREE.Mesh(comGeom, comMat));
    });

    // ─── State management ─────────────────────────────────────
    let currentState = 2;

    function setState(state: number) {
      currentState = state;
      wireGroup.visible = state === 0;
      texGroup.visible = state === 1;
      simGroup.visible = state === 2;

      if (physicsLabels) {
        physicsLabels.style.opacity = state === 2 ? '1' : '0';
      }

      statePills.forEach((pill) => {
        const pillState = parseInt(pill.getAttribute('data-state') || '0');
        if (pillState === state) {
          pill.classList.add('active');
        } else {
          pill.classList.remove('active');
        }
      });
    }

    // Initialize active pill to SimReady
    setState(2);

    statePills.forEach((pill) => {
      pill.addEventListener('click', () => {
        const state = parseInt(pill.getAttribute('data-state') || '0');
        setState(state);
      });
    });

    // ─── Mouse interaction ────────────────────────────────────
    let isDragging = false;
    let previousMouseX = 0;
    let rotationY = 0;
    let targetRotationY = 0;

    container.addEventListener('pointerdown', (e) => {
      isDragging = true;
      previousMouseX = e.clientX;
    });

    window.addEventListener('pointermove', (e) => {
      if (isDragging) {
        const deltaX = e.clientX - previousMouseX;
        targetRotationY += deltaX * 0.008;
        previousMouseX = e.clientX;
      }
    });

    window.addEventListener('pointerup', () => {
      isDragging = false;
    });

    // ─── Animation loop ───────────────────────────────────────
    function animate() {
      requestAnimationFrame(animate);

      if (!isDragging) {
        targetRotationY += 0.003;
      }
      rotationY += (targetRotationY - rotationY) * 0.08;
      modelGroup.rotation.y = rotationY;

      // Gentle bob
      modelGroup.position.y = Math.sin(Date.now() * 0.001) * 0.03;

      // Pulse collision mesh & CoM in SimReady state
      if (currentState === 2) {
        physicsWireMat.opacity = 0.2 + Math.sin(Date.now() * 0.003) * 0.15;
        comMat.color.setHSL(0.12, 1, 0.5 + Math.sin(Date.now() * 0.004) * 0.1);
      }

      renderer.render(scene, camera);
    }

    animate();
  }
</script>

<style>
  .state-pill {
    color: #5a6478;
    border-color: rgba(235, 233, 224, 0.08);
    background: rgba(10, 12, 24, 0.8);
    backdrop-filter: blur(8px);
  }
  .state-pill:hover {
    color: #ebe9e0;
    border-color: rgba(235, 233, 224, 0.14);
  }
  .state-pill.active {
    color: #d4e017;
    border-color: rgba(212, 224, 23, 0.4);
    background: rgba(212, 224, 23, 0.08);
  }
</style>
