---
---

<section id="compatibility" class="relative py-28 px-6">
  <div class="max-w-6xl mx-auto">
    <div class="text-center mb-16 reveal">
      <h2 class="text-3xl sm:text-4xl font-bold tracking-tight text-text mb-4">
        Works everywhere your robots train
      </h2>
    </div>

    <!-- Platform logos -->
    <div class="flex flex-wrap justify-center items-center gap-10 sm:gap-14 lg:gap-20 reveal">

      <!-- NVIDIA Isaac Sim -->
      <div class="group flex flex-col items-center gap-3 opacity-70 hover:opacity-100 transition-opacity duration-300">
        <img src="/omniverse-icon.svg" alt="NVIDIA Omniverse" class="h-14 sm:h-16 w-auto text-white" style="filter: brightness(0) invert(1);" />
        <span class="text-sm text-text-secondary font-medium">NVIDIA Isaac Sim</span>
      </div>

      <!-- MuJoCo -->
      <div class="group flex flex-col items-center gap-3 opacity-70 hover:opacity-100 transition-opacity duration-300">
        <span class="text-3xl sm:text-4xl font-bold tracking-tight text-white" style="font-family: 'Geist', system-ui, sans-serif;">MuJoCo</span>
      </div>

      <!-- Gazebo -->
      <div class="group flex flex-col items-center gap-3 opacity-70 hover:opacity-100 transition-opacity duration-300">
        <img src="/gazebo.png" alt="Gazebo" class="h-16 sm:h-20 w-auto invert" />
      </div>

      <!-- Unreal Engine -->
      <div class="group flex flex-col items-center gap-3 opacity-70 hover:opacity-100 transition-opacity duration-300">
        <img src="/unreal-engine.png" alt="Unreal Engine" class="h-16 sm:h-20 w-auto invert" />
      </div>

    </div>
  </div>
</section>
