---
---

<section id="compatibility" class="relative py-28 px-6">
  <div class="max-w-6xl mx-auto">
    <div class="text-center mb-16 reveal">
      <h2 class="text-3xl sm:text-4xl font-bold tracking-tight text-text mb-4">
        Works everywhere your robots train
      </h2>
    </div>

    <!-- Platform logos -->
    <div class="flex flex-wrap justify-center items-center gap-10 sm:gap-14 lg:gap-20 reveal">

      <!-- NVIDIA Isaac Sim -->
      <div class="group flex flex-col items-center gap-3 opacity-70 hover:opacity-100 transition-opacity duration-300">
        <svg class="w-28 h-28 sm:w-32 sm:h-32" viewBox="0 0 120 120" fill="none">
          <!-- Green square -->
          <rect x="32" y="12" width="52" height="52" fill="#76B900"/>
          <!-- Eye shape -->
          <path d="M58 18C45 18 36 28 36 40C36 52 45 62 58 62C71 62 80 52 80 40" stroke="white" stroke-width="6" fill="none" stroke-linecap="round"/>
          <path d="M58 28C51 28 46 34 46 40C46 46 51 52 58 52C65 52 70 46 70 40" stroke="white" stroke-width="5" fill="none" stroke-linecap="round"/>
          <circle cx="58" cy="40" r="6" fill="white"/>
          <!-- Text -->
          <text x="60" y="85" text-anchor="middle" fill="#A1A1AA" font-family="Geist, system-ui, sans-serif" font-weight="700" font-size="14" letter-spacing="1">NVIDIA</text>
          <text x="60" y="102" text-anchor="middle" fill="#FAFAFA" font-family="Geist, system-ui, sans-serif" font-weight="600" font-size="12">Isaac Sim</text>
        </svg>
      </div>

      <!-- MuJoCo -->
      <div class="group flex flex-col items-center gap-3 opacity-70 hover:opacity-100 transition-opacity duration-300">
        <svg class="w-28 h-28 sm:w-32 sm:h-32" viewBox="0 0 120 120" fill="none">
          <text x="60" y="50" text-anchor="middle" fill="#4A7EF5" font-family="Geist, system-ui, sans-serif" font-weight="700" font-size="28" letter-spacing="-0.5">MuJoCo</text>
          <text x="60" y="74" text-anchor="middle" fill="#A1A1AA" font-family="Geist, system-ui, sans-serif" font-weight="400" font-size="10">Advanced physics</text>
          <text x="60" y="88" text-anchor="middle" fill="#A1A1AA" font-family="Geist, system-ui, sans-serif" font-weight="400" font-size="10">simulation</text>
          <!-- Decorative polygon lines -->
          <polygon points="20,15 100,10 110,55 95,95 25,90 10,50" fill="none" stroke="#4A7EF5" stroke-width="0.8" opacity="0.3"/>
          <polygon points="15,20 95,18 105,50 90,88 22,85 8,45" fill="none" stroke="#4A7EF5" stroke-width="0.5" opacity="0.15"/>
        </svg>
      </div>

      <!-- Gazebo -->
      <div class="group flex flex-col items-center gap-3 opacity-70 hover:opacity-100 transition-opacity duration-300">
        <svg class="w-28 h-28 sm:w-32 sm:h-32" viewBox="0 0 120 120" fill="none">
          <!-- Cube shape inspired by Gazebo logo -->
          <path d="M60 20L90 38V68L60 86L30 68V38Z" fill="none" stroke="#d4e017" stroke-width="2.5"/>
          <path d="M60 20L90 38L60 52L30 38Z" fill="#d4e017" opacity="0.3"/>
          <path d="M60 52V86L30 68V38Z" fill="#d4e017" opacity="0.1"/>
          <path d="M60 52V86L90 68V38Z" fill="#d4e017" opacity="0.2"/>
          <!-- Inner accent -->
          <path d="M60 30L78 40L60 50L42 40Z" fill="#d4e017" opacity="0.6"/>
          <!-- Text -->
          <text x="60" y="108" text-anchor="middle" fill="#FAFAFA" font-family="Geist, system-ui, sans-serif" font-weight="500" font-size="13" letter-spacing="3">GAZEBO</text>
        </svg>
      </div>

      <!-- Unreal Engine -->
      <div class="group flex flex-col items-center gap-3 opacity-70 hover:opacity-100 transition-opacity duration-300">
        <svg class="w-28 h-28 sm:w-32 sm:h-32" viewBox="0 0 120 120" fill="none">
          <!-- Circle -->
          <circle cx="60" cy="46" r="30" fill="#FAFAFA" opacity="0.9"/>
          <circle cx="60" cy="46" r="27" fill="#0A0A0B"/>
          <!-- U letterform -->
          <path d="M48 32V52C48 58 53 62 60 62C67 62 72 58 72 52V32" stroke="#FAFAFA" stroke-width="4" fill="none" stroke-linecap="round"/>
          <!-- Decorative serif on U -->
          <path d="M52 32L44 36" stroke="#FAFAFA" stroke-width="2.5" stroke-linecap="round"/>
          <!-- Text -->
          <text x="60" y="95" text-anchor="middle" fill="#FAFAFA" font-family="Geist, system-ui, sans-serif" font-weight="700" font-size="11" letter-spacing="1.5">UNREAL</text>
          <text x="60" y="110" text-anchor="middle" fill="#A1A1AA" font-family="Geist, system-ui, sans-serif" font-weight="600" font-size="10" letter-spacing="1">ENGINE</text>
        </svg>
      </div>


    </div>
  </div>
</section>
