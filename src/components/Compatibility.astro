---
import { PLATFORMS } from '../lib/constants';
---

<section id="compatibility" class="relative py-28 px-6">
  <div class="max-w-6xl mx-auto">
    <div class="text-center mb-16 reveal">
      <h2 class="text-3xl sm:text-4xl font-bold tracking-tight text-text mb-4">
        Works everywhere your robots train
      </h2>
    </div>

    <!-- Platform badges -->
    <div class="flex flex-wrap justify-center gap-4 mb-10 reveal">
      {PLATFORMS.map((platform) => (
        <div class="flex items-center gap-2.5 px-5 py-3 rounded-lg border border-[rgba(255,255,255,0.06)] bg-bg-card hover:border-[rgba(255,255,255,0.12)] transition-colors">
          <svg class="w-4 h-4 text-green flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
          </svg>
          <span class="text-sm font-medium text-text">{platform.name}</span>
        </div>
      ))}
    </div>

    <!-- NVIDIA Inception badge -->
    <div class="flex justify-center mb-10 reveal reveal-delay-1">
      <div class="flex items-center gap-3 px-5 py-3 rounded-lg border border-green/20 bg-green/[0.04]">
        <!-- NVIDIA logo simplified -->
        <svg class="w-5 h-5 text-green" viewBox="0 0 24 24" fill="currentColor">
          <path d="M8.948 8.798V7.157c.12-.007.243-.011.368-.011 2.27 0 3.655 1.95 3.655 1.95s-1.566 2.222-3.252 2.222c-.284 0-.544-.052-.771-.143V8.798zm0-3.236v-1.39l.204-.013c3.652-.186 6.073 2.862 6.073 2.862s-3.342 3.753-5.694 3.753c-.214 0-.406-.027-.583-.073V5.562zm0 7.607v.586H7.404c.009-4.272 3.236-6.6 5.53-6.6.153 0 .281.013.281.013v1.584c-.098-.013-.202-.02-.31-.02-1.727 0-3.32 1.543-3.957 4.437zM2 12c0 5.523 4.477 10 10 10s10-4.477 10-10S17.523 2 12 2 2 6.477 2 12z"/>
        </svg>
        <div class="text-sm">
          <span class="text-green font-medium">NVIDIA Inception</span>
          <span class="text-text-secondary"> Program Member</span>
        </div>
      </div>
    </div>

    <!-- Output format info -->
    <div class="text-center reveal reveal-delay-2">
      <p class="text-sm text-text-secondary font-mono">
        Output: <span class="text-text">OpenUSD (.usd/.usda)</span> with USDPhysics schemas
        <span class="mx-2 text-[rgba(255,255,255,0.2)]">|</span>
        Also exports: <span class="text-text">URDF</span>, <span class="text-text">MJCF</span>, <span class="text-text">.obj+metadata</span>
      </p>
    </div>
  </div>
</section>
