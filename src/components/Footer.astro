---
---

<footer class="relative py-16 px-6 border-t border-[rgba(255,255,255,0.06)]">
  <div class="max-w-6xl mx-auto">
    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-10 mb-12">
      <!-- Brand -->
      <div class="sm:col-span-2 lg:col-span-1">
        <a href="/" class="flex items-center gap-2.5 text-text font-semibold text-sm tracking-tight mb-4">
          <svg class="w-6 h-6" viewBox="0 0 32 32" fill="none">
            <rect width="32" height="32" rx="8" fill="#F59E0B"/>
            <path d="M8 24L16 8L24 24H20L16 15L12 24H8Z" fill="#0A0A0B" stroke="#0A0A0B" stroke-width="0.5"/>
          </svg>
          <span>SimReady <span class="text-text-secondary font-normal">by ArtLabs</span></span>
        </a>
        <p class="text-sm text-text-secondary leading-relaxed max-w-xs">
          The missing middleware between raw 3D and robot training.
        </p>
      </div>

      <!-- Links -->
      <div>
        <h4 class="text-xs font-semibold text-text-secondary uppercase tracking-wider mb-4">Product</h4>
        <ul class="space-y-2.5">
          <li><a href="#how-it-works" class="text-sm text-text-secondary hover:text-text transition-colors">How it works</a></li>
          <li><a href="#compatibility" class="text-sm text-text-secondary hover:text-text transition-colors">Compatibility</a></li>
          <li><a href="#tech" class="text-sm text-text-secondary hover:text-text transition-colors">Technical details</a></li>
        </ul>
      </div>

      <div>
        <h4 class="text-xs font-semibold text-text-secondary uppercase tracking-wider mb-4">Company</h4>
        <ul class="space-y-2.5">
          <li><a href="https://artlabs.ai" target="_blank" rel="noopener noreferrer" class="text-sm text-text-secondary hover:text-text transition-colors">artlabs.ai</a></li>
          <li><a href="https://twitter.com/artlabs_ai" target="_blank" rel="noopener noreferrer" class="text-sm text-text-secondary hover:text-text transition-colors">Twitter / X</a></li>
          <li><a href="https://linkedin.com/company/artlabs-ai" target="_blank" rel="noopener noreferrer" class="text-sm text-text-secondary hover:text-text transition-colors">LinkedIn</a></li>
          <li><a href="https://github.com/ArtLabs-ai" target="_blank" rel="noopener noreferrer" class="text-sm text-text-secondary hover:text-text transition-colors">GitHub</a></li>
        </ul>
      </div>

      <!-- NVIDIA Inception -->
      <div>
        <h4 class="text-xs font-semibold text-text-secondary uppercase tracking-wider mb-4">Programs</h4>
        <div class="flex items-center gap-2.5 px-4 py-3 rounded-lg border border-[rgba(255,255,255,0.06)] bg-bg-card inline-flex">
          <svg class="w-5 h-5 text-green" viewBox="0 0 24 24" fill="currentColor">
            <path d="M8.948 8.798V7.157c.12-.007.243-.011.368-.011 2.27 0 3.655 1.95 3.655 1.95s-1.566 2.222-3.252 2.222c-.284 0-.544-.052-.771-.143V8.798zm0-3.236v-1.39l.204-.013c3.652-.186 6.073 2.862 6.073 2.862s-3.342 3.753-5.694 3.753c-.214 0-.406-.027-.583-.073V5.562zm0 7.607v.586H7.404c.009-4.272 3.236-6.6 5.53-6.6.153 0 .281.013.281.013v1.584c-.098-.013-.202-.02-.31-.02-1.727 0-3.32 1.543-3.957 4.437zM2 12c0 5.523 4.477 10 10 10s10-4.477 10-10S17.523 2 12 2 2 6.477 2 12z"/>
          </svg>
          <div class="text-xs">
            <div class="text-green font-medium">NVIDIA Inception</div>
            <div class="text-text-secondary">Program Member</div>
          </div>
        </div>
      </div>
    </div>

    <!-- Track record -->
    <div class="py-6 border-t border-[rgba(255,255,255,0.06)] mb-6">
      <p class="text-sm text-text-secondary text-center">
        Backed by experience: <span class="text-text">20k+ high-fidelity 3D assets</span> delivered to enterprises.
        <span class="text-text">10M+ immersive experiences</span> delivered last year alone.
      </p>
    </div>

    <!-- Bottom -->
    <div class="flex flex-col sm:flex-row items-center justify-between gap-4 text-xs text-text-secondary">
      <p>&copy; 2026 ArtLabs. All rights reserved.</p>
      <p>NVIDIA Inception Program member. SimReady and OpenUSD are standards by NVIDIA and the Alliance for OpenUSD.</p>
    </div>
  </div>
</footer>
