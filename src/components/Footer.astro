---
import Logo from './Logo.astro';
---

<footer class="relative py-16 px-6 border-t border-[rgba(235,233,224,0.06)]">
  <div class="max-w-6xl mx-auto">
    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-10 mb-12">
      <!-- Brand -->
      <div class="sm:col-span-2 lg:col-span-1">
        <div class="mb-4">
          <Logo />
        </div>
        <p class="text-sm text-text-secondary leading-relaxed max-w-xs">
          The missing middleware between raw 3D and robot training.
        </p>
      </div>

      <!-- Links -->
      <div>
        <h4 class="text-xs font-semibold text-text-secondary uppercase tracking-wider mb-4">Product</h4>
        <ul class="space-y-2.5">
          <li><a href="#how-it-works" class="text-sm text-text-secondary hover:text-text transition-colors">How it works</a></li>
          <li><a href="#use-cases" class="text-sm text-text-secondary hover:text-text transition-colors">Use Cases</a></li>
          <li><a href="#pricing" class="text-sm text-text-secondary hover:text-text transition-colors">Pricing</a></li>
        </ul>
      </div>

      <div>
        <h4 class="text-xs font-semibold text-text-secondary uppercase tracking-wider mb-4">Company</h4>
        <ul class="space-y-2.5">
          <li><a href="https://artlabs.ai" target="_blank" rel="noopener noreferrer" class="text-sm text-text-secondary hover:text-text transition-colors">artlabs.ai</a></li>
          <li><a href="https://twitter.com/artlabs_ai" target="_blank" rel="noopener noreferrer" class="text-sm text-text-secondary hover:text-text transition-colors">Twitter / X</a></li>
          <li><a href="https://linkedin.com/company/artlabs-ai" target="_blank" rel="noopener noreferrer" class="text-sm text-text-secondary hover:text-text transition-colors">LinkedIn</a></li>
        </ul>
      </div>

      <!-- NVIDIA Inception Logo -->
      <div class="flex items-end">
        <img src="/nvidia-inception.png" alt="NVIDIA Inception Program member badge — Rigyd is part of the NVIDIA Inception accelerator for AI startups" class="w-36 opacity-80" />
      </div>
    </div>

    <!-- Bottom -->
    <div class="pt-6 border-t border-[rgba(235,233,224,0.06)]">
      <div class="flex flex-col sm:flex-row items-center justify-between gap-4 text-xs text-text-secondary">
        <p>&copy; 2026 Rigyd — a product by <a href="https://artlabs.ai" target="_blank" rel="noopener noreferrer" class="text-text-secondary hover:text-text transition-colors underline decoration-dotted underline-offset-2">artlabs</a>. All rights reserved.</p>
        <div class="flex items-center gap-4">
          <a href="https://artlabs.ai/page/user-agreement" target="_blank" rel="noopener noreferrer" class="text-text-secondary hover:text-text transition-colors underline decoration-dotted underline-offset-2">User Agreement</a>
          <a href="https://artlabs.ai/page/privacy-policy" target="_blank" rel="noopener noreferrer" class="text-text-secondary hover:text-text transition-colors underline decoration-dotted underline-offset-2">Privacy Policy</a>
          <span>Last updated: April 2026</span>
        </div>
      </div>
    </div>
  </div>
</footer>
