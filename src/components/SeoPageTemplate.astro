---
import type { SeoPage } from '../lib/seo-pages';
import TryNowButton from './TryNowButton.astro';
import Logo from './Logo.astro';
import Footer from './Footer.astro';
import { SITE } from '../lib/constants';

interface Props {
  page: SeoPage;
}

const { page } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={page.metaDescription} />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href={`${SITE.url}${page.canonicalPath}`} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Rigyd" />
    <meta property="og:title" content={page.metaTitle} />
    <meta property="og:description" content={page.metaDescription} />
    <meta property="og:image" content={`${SITE.url}/og-image.png`} />
    <meta property="og:url" content={`${SITE.url}${page.canonicalPath}`} />
    <meta property="og:locale" content="en_US" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@artlabs_ai" />
    <meta name="twitter:title" content={page.metaTitle} />
    <meta name="twitter:description" content={page.metaDescription} />
    <meta name="twitter:image" content={`${SITE.url}/og-image.png`} />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <link rel="preconnect" href="https://cdn.jsdelivr.net" crossorigin />
    <style is:inline>
      @font-face {
        font-family: 'Geist Mono';
        src: url('https://cdn.jsdelivr.net/npm/geist@1.3.1/dist/fonts/geist-mono/GeistMono-Regular.woff2') format('woff2');
        font-weight: 400;
        font-style: normal;
        font-display: swap;
      }
    </style>

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <title>{page.metaTitle}</title>

    <!-- RB2B Tracking -->
    <script is:inline>!function(key) {if (window.reb2b) return;window.reb2b = {loaded: true};var s = document.createElement("script");s.async = true;s.src = "https://ddwl4m2hdecbv.cloudfront.net/b/" + key + "/" + key + ".js.gz";document.getElementsByTagName("script")[0].parentNode.insertBefore(s, document.getElementsByTagName("script")[0]);}("EN4M0HLPX5OM");</script>

    <!-- Google Analytics -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-J1C7YQDPKX"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-J1C7YQDPKX');
    </script>

    <!-- Microsoft Clarity -->
    <script is:inline type="text/javascript">
      (function(c,l,a,r,i,t,y){
          c[a]=c[a]||function(){(c[a].q=c[a].q||[]).push(arguments)};
          t=l.createElement(r);t.async=1;t.src="https://www.clarity.ms/tag/"+i;
          y=l.getElementsByTagName(r)[0];y.parentNode.insertBefore(t,y);
      })(window, document, "clarity", "script", "wcxto9p2i4");
    </script>

    <!-- Structured Data: BreadcrumbList -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        {
          "@type": "ListItem",
          "position": 1,
          "name": "Home",
          "item": SITE.url,
        },
        {
          "@type": "ListItem",
          "position": 2,
          "name": page.title,
          "item": `${SITE.url}${page.canonicalPath}`,
        },
      ],
    })} />

    <!-- Structured Data: Page-specific -->
    <script type="application/ld+json" set:html={JSON.stringify(
      page.schemaType === 'SoftwareApplication'
        ? {
            "@context": "https://schema.org",
            "@type": "SoftwareApplication",
            "name": `Rigyd — ${page.title}`,
            "applicationCategory": "DeveloperApplication",
            "description": page.metaDescription,
            "url": `${SITE.url}${page.canonicalPath}`,
            "operatingSystem": "Web",
            "offers": {
              "@type": "Offer",
              "price": "29",
              "priceCurrency": "USD",
              "billingIncrement": "monthly",
            },
            "creator": {
              "@type": "Organization",
              "name": "artlabs",
              "url": "https://artlabs.ai",
            },
          }
        : {
            "@context": "https://schema.org",
            "@type": "Article",
            "headline": page.title,
            "description": page.metaDescription,
            "url": `${SITE.url}${page.canonicalPath}`,
            "publisher": {
              "@type": "Organization",
              "name": "Rigyd",
              "url": SITE.url,
            },
            "datePublished": "2026-04-07",
            "dateModified": "2026-04-07",
          }
    )} />
  </head>

  <body class="grid-bg min-h-screen relative">
    <!-- Nav -->
    <nav class="fixed top-0 left-0 right-0 z-50 backdrop-blur-md bg-bg/80 border-b border-[rgba(255,255,255,0.06)]">
      <div class="max-w-6xl mx-auto px-4 sm:px-6 h-14 flex items-center justify-between">
        <Logo />
        <div class="flex items-center gap-6">
          <a href="/#how-it-works" class="text-sm text-text-secondary hover:text-text transition-colors hidden sm:block">How it works</a>
          <a href="/#use-cases" class="text-sm text-text-secondary hover:text-text transition-colors hidden sm:block">Use Cases</a>
          <a href="/#pricing" class="text-sm text-text-secondary hover:text-text transition-colors hidden sm:block">Pricing</a>
          <TryNowButton size="default" label="Try free" />
        </div>
      </div>
    </nav>

    <main>
      <!-- Hero -->
      <section class="relative pt-32 pb-20 px-4 sm:px-6">
        <div class="absolute top-1/4 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[800px] h-[500px] bg-amber/[0.04] rounded-full blur-[120px] pointer-events-none"></div>
        <div class="relative z-10 max-w-4xl mx-auto text-center">
          <nav class="mb-8 text-sm text-text-secondary" aria-label="Breadcrumb">
            <a href="/" class="hover:text-text transition-colors">Home</a>
            <span class="mx-2">/</span>
            <span class="text-text">{page.title}</span>
          </nav>
          <h1 class="text-4xl sm:text-5xl lg:text-[3.5rem] font-bold leading-[1.08] tracking-tight text-text mb-6" set:html={page.heroHeadline} />
          <p class="text-lg sm:text-xl text-text-secondary leading-relaxed max-w-2xl mx-auto mb-8">
            {page.heroSub}
          </p>
          <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
            <TryNowButton size="large" />
            <a href="/#how-it-works" class="inline-flex items-center gap-2 px-6 py-3.5 text-sm font-medium text-text-secondary hover:text-text border border-border-hover rounded-lg transition-colors">
              See how it works
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" />
              </svg>
            </a>
          </div>
        </div>
      </section>

      <!-- Pain Points -->
      <section class="py-20 px-4 sm:px-6">
        <div class="max-w-6xl mx-auto">
          <h2 class="text-2xl sm:text-3xl font-bold tracking-tight text-text mb-4 text-center">The problem</h2>
          <p class="text-text-secondary text-center mb-12 max-w-2xl mx-auto">Why existing workflows fall short.</p>
          <div class="grid md:grid-cols-3 gap-6">
            {page.painPoints.map((point) => (
              <div class="rounded-2xl border border-[rgba(255,255,255,0.06)] bg-bg-card p-8">
                <h3 class="text-lg font-semibold text-text mb-3">{point.title}</h3>
                <p class="text-sm text-text-secondary leading-relaxed">{point.description}</p>
              </div>
            ))}
          </div>
        </div>
      </section>

      <!-- How Rigyd Helps -->
      <section class="py-20 px-4 sm:px-6">
        <div class="max-w-6xl mx-auto">
          <h2 class="text-2xl sm:text-3xl font-bold tracking-tight text-text mb-4 text-center">How <span class="text-amber">Rigyd</span> helps</h2>
          <p class="text-text-secondary text-center mb-12 max-w-2xl mx-auto">AI-native infrastructure that automates the hard parts.</p>
          <div class="grid md:grid-cols-3 gap-6">
            {page.howRigydHelps.map((item) => (
              <div class="rounded-2xl border border-amber/10 bg-amber/[0.03] p-8">
                <h3 class="text-lg font-semibold text-text mb-3">{item.title}</h3>
                <p class="text-sm text-text-secondary leading-relaxed">{item.description}</p>
              </div>
            ))}
          </div>
        </div>
      </section>

      <!-- Stats -->
      <section class="py-20 px-4 sm:px-6">
        <div class="max-w-4xl mx-auto">
          <div class="grid sm:grid-cols-3 gap-8 text-center">
            {page.stats.map((stat) => (
              <div>
                <div class="text-4xl sm:text-5xl font-bold text-amber mb-2 font-mono tracking-tight">{stat.value}</div>
                <p class="text-sm text-text-secondary">{stat.label}</p>
              </div>
            ))}
          </div>
        </div>
      </section>

      <!-- CTA -->
      <section class="py-24 px-4 sm:px-6">
        <div class="max-w-4xl mx-auto text-center">
          <h2 class="text-3xl sm:text-4xl font-bold tracking-tight text-text mb-4">{page.ctaHeadline}</h2>
          <p class="text-lg text-text-secondary mb-8 max-w-xl mx-auto">{page.ctaSub}</p>
          <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
            <TryNowButton size="large" />
            <a href="/#pricing" class="inline-flex items-center gap-2 px-6 py-3.5 text-sm font-medium text-text-secondary hover:text-text border border-border-hover rounded-lg transition-colors">
              View pricing
            </a>
          </div>
          <p class="mt-6 text-xs text-text-secondary">Starts at $29/month. 30 SimReady objects included.</p>
        </div>
      </section>

      <!-- Internal Links -->
      <section class="py-16 px-4 sm:px-6 border-t border-[rgba(235,233,224,0.06)]">
        <div class="max-w-6xl mx-auto">
          <h2 class="text-xl font-bold text-text mb-8 text-center">Explore more</h2>
          <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
            <a href="/for/isaac-sim" class="block p-4 rounded-xl border border-[rgba(255,255,255,0.06)] hover:border-amber/20 transition-colors">
              <p class="text-sm font-semibold text-text">SimReady for Isaac Sim</p>
              <p class="text-xs text-text-secondary mt-1">OpenUSD assets validated for NVIDIA Isaac Sim</p>
            </a>
            <a href="/for/mujoco" class="block p-4 rounded-xl border border-[rgba(255,255,255,0.06)] hover:border-amber/20 transition-colors">
              <p class="text-sm font-semibold text-text">Models for MuJoCo</p>
              <p class="text-xs text-text-secondary mt-1">Physics-accurate assets for robot learning</p>
            </a>
            <a href="/for/gazebo" class="block p-4 rounded-xl border border-[rgba(255,255,255,0.06)] hover:border-amber/20 transition-colors">
              <p class="text-sm font-semibold text-text">Assets for Gazebo</p>
              <p class="text-xs text-text-secondary mt-1">Simulation-ready models for ROS 2</p>
            </a>
            <a href="/verticals/warehouse-robots" class="block p-4 rounded-xl border border-[rgba(255,255,255,0.06)] hover:border-amber/20 transition-colors">
              <p class="text-sm font-semibold text-text">Warehouse Simulation</p>
              <p class="text-xs text-text-secondary mt-1">50,000+ SKUs need physics properties</p>
            </a>
            <a href="/verticals/humanoid-robots" class="block p-4 rounded-xl border border-[rgba(255,255,255,0.06)] hover:border-amber/20 transition-colors">
              <p class="text-sm font-semibold text-text">Humanoid Robots</p>
              <p class="text-xs text-text-secondary mt-1">Whole-body interaction training assets</p>
            </a>
            <a href="/use-cases/sim-to-real" class="block p-4 rounded-xl border border-[rgba(255,255,255,0.06)] hover:border-amber/20 transition-colors">
              <p class="text-sm font-semibold text-text">Sim-to-Real Transfer</p>
              <p class="text-xs text-text-secondary mt-1">Close the gap with accurate physics data</p>
            </a>
          </div>
        </div>
      </section>
    </main>

    <Footer />
  </body>
</html>
