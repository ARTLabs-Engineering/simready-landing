---
import { TECH_DETAILS } from '../lib/constants';
---

<section id="tech" class="relative py-28 px-6">
  <div class="max-w-3xl mx-auto">
    <div class="text-center mb-16 reveal">
      <h2 class="text-3xl sm:text-4xl font-bold tracking-tight text-text mb-4">
        Under the hood
      </h2>
      <p class="text-text-secondary text-lg">
        Technical details for engineers who want to know how it works.
      </p>
    </div>

    <!-- Accordion -->
    <div class="space-y-3 reveal" role="region" aria-label="Technical details">
      {TECH_DETAILS.map((item, i) => (
        <div class="accordion-item rounded-xl border border-[rgba(255,255,255,0.06)] bg-bg-card overflow-hidden hover:border-[rgba(255,255,255,0.12)] transition-colors">
          <button
            class="accordion-trigger w-full flex items-center justify-between px-6 py-4 text-left cursor-pointer"
            aria-expanded="false"
            aria-controls={`accordion-${i}`}
            id={`accordion-btn-${i}`}
          >
            <span class="text-sm font-semibold text-text pr-4">{item.title}</span>
            <svg class="accordion-chevron w-4 h-4 text-text-secondary flex-shrink-0 transition-transform duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
            </svg>
          </button>
          <div
            class="accordion-content"
            id={`accordion-${i}`}
            role="region"
            aria-labelledby={`accordion-btn-${i}`}
          >
            <div>
              <div class="px-6 pb-4">
                <p class="text-sm text-text-secondary leading-relaxed">{item.content}</p>
              </div>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<script>
  document.querySelectorAll('.accordion-trigger').forEach((trigger) => {
    trigger.addEventListener('click', () => {
      const expanded = trigger.getAttribute('aria-expanded') === 'true';
      const contentId = trigger.getAttribute('aria-controls');
      const content = document.getElementById(contentId || '');
      const chevron = trigger.querySelector('.accordion-chevron');

      // Close all others
      document.querySelectorAll('.accordion-trigger').forEach((otherTrigger) => {
        if (otherTrigger !== trigger) {
          otherTrigger.setAttribute('aria-expanded', 'false');
          const otherId = otherTrigger.getAttribute('aria-controls');
          const otherContent = document.getElementById(otherId || '');
          const otherChevron = otherTrigger.querySelector('.accordion-chevron');
          otherContent?.classList.remove('open');
          otherChevron?.style.setProperty('transform', 'rotate(0deg)');
        }
      });

      // Toggle current
      trigger.setAttribute('aria-expanded', expanded ? 'false' : 'true');
      if (expanded) {
        content?.classList.remove('open');
        chevron?.style.setProperty('transform', 'rotate(0deg)');
      } else {
        content?.classList.add('open');
        chevron?.style.setProperty('transform', 'rotate(180deg)');
      }
    });
  });
</script>
