<section id="mission" class="relative py-32 sm:py-40 px-6">
  <!-- Top decorative line -->
  <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[300px] h-px bg-gradient-to-r from-transparent via-amber/20 to-transparent"></div>

  <div class="max-w-4xl mx-auto text-center reveal">
    <h2 class="text-3xl sm:text-4xl md:text-5xl font-bold leading-tight tracking-tight text-text mb-6">
      The future isn't man or machine&nbsp;&mdash;<br />
      it's both, working
      <span class="relative inline-block">
        <span class="relative z-10 text-amber">together</span>
        <span class="absolute bottom-0 left-0 right-0 h-[3px] bg-gradient-to-r from-amber/0 via-amber/60 to-amber/0 rounded-full"></span>
      </span>.
    </h2>

    <p class="text-lg text-text-secondary max-w-xl mx-auto leading-relaxed">
      We're building the AI-native 3D data infrastructure to make that future arrive faster.
    </p>
  </div>

  <!-- Bottom decorative line -->
  <div class="absolute bottom-0 left-1/2 -translate-x-1/2 w-[300px] h-px bg-gradient-to-r from-transparent via-[rgba(255,255,255,0.06)] to-transparent"></div>
</section>
