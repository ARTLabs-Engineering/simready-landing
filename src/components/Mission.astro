---
---

<section id="mission" class="relative py-32 sm:py-44 px-6 overflow-hidden">
  <!-- Ambient glow -->
  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[400px] bg-amber/[0.03] rounded-full blur-[100px] pointer-events-none"></div>

  <!-- Top decorative line -->
  <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[400px] h-px bg-gradient-to-r from-transparent via-amber/20 to-transparent"></div>

  <div class="max-w-4xl mx-auto text-center relative z-10 reveal">
    <p class="text-xs font-mono text-amber/60 tracking-wider uppercase mb-8">Our mission</p>

    <h2 class="text-3xl sm:text-4xl md:text-[2.75rem] lg:text-5xl font-bold leading-[1.15] tracking-tight text-text mb-8">
      Robotics will be the<br class="hidden sm:block" />
      <span class="italic text-amber">largest industry</span> in history.
    </h2>

    <p class="text-lg sm:text-xl text-text/80 max-w-2xl mx-auto leading-relaxed mb-10">
      We're creating the AI-native 3D infrastructure to make that future arrive <span class="relative inline-block"><span class="relative z-10 font-semibold text-amber">faster</span><span class="absolute bottom-0 left-0 right-0 h-[3px] bg-gradient-to-r from-amber/0 via-amber/50 to-amber/0 rounded-full"></span></span>.
    </p>

    <div class="w-16 h-px bg-gradient-to-r from-transparent via-amber/40 to-transparent mx-auto mb-10"></div>

    <p class="text-lg sm:text-xl text-text/80 max-w-lg mx-auto leading-relaxed">
      The future isn't man or machine — it's both, working
      <span class="relative inline-block">
        <span class="relative z-10 font-semibold text-amber">together</span>
        <span class="absolute bottom-0 left-0 right-0 h-[3px] bg-gradient-to-r from-amber/0 via-amber/50 to-amber/0 rounded-full"></span>
      </span>.
    </p>
  </div>

  <!-- Bottom decorative line -->
  <div class="absolute bottom-0 left-1/2 -translate-x-1/2 w-[300px] h-px bg-gradient-to-r from-transparent via-[rgba(255,255,255,0.06)] to-transparent"></div>
</section>
